# Production env template — values here are placeholders.
# On Railway, set each one via the dashboard (or `railway variables set`).
# Never commit a populated copy to git.

# ── Database (Railway plugin) ────────────────────────────────────
# Railway exposes DATABASE_URL automatically when you attach Postgres.
# Format: postgresql://USER:PASS@HOST:PORT/DB  (we normalize the prefix.)
DATABASE_URL=
# When deploying to Railway, alembic and the runtime can share the same
# user — leave ALEMBIC_DATABASE_URL unset.  Set this only if you create a
# dedicated migration role with BYPASSRLS.
ALEMBIC_DATABASE_URL=

# ── Redis (Railway plugin) ───────────────────────────────────────
REDIS_URL=

# ── Auth ─────────────────────────────────────────────────────────
# Generate a 64+ char random string. Rotating this invalidates all
# outstanding JWTs, so do it on schedule, not in panic.
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
# Leave Google OAuth off until you've registered the prod redirect URI.
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Storage (Cloudflare R2) ──────────────────────────────────────
# R2 is S3-compatible; use the bucket's S3 API endpoint.
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=coachito-prod
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Public asset host (the bucket's custom domain or R2 public URL).
S3_PUBLIC_HOST=

# ── Email (Resend) ───────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_FROM=Coachito <no-reply@your-domain.com>

# ── App URLs ─────────────────────────────────────────────────────
# The single deploy origin — used in magic-link emails + invite landings.
WEB_URL=https://your-app.up.railway.app
# Only needed if the FE is on a different origin than the API (3-service
# split deploy).  Empty in the default 1-service all-in-one setup.
ALLOWED_ORIGINS=

# ── AI (Gemini) ──────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=12

# ── Observability ────────────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=production
