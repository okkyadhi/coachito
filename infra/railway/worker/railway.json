{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/api/Dockerfile.prod"
  },
  "deploy": {
    "startCommand": "rq worker --url $REDIS_URL default",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
