# ── Database ─────────────────────────────────────────────────────
# Local: postgresql+asyncpg://racademy:racademy@localhost:5432/racademy
# Docker-internal uses service name "postgres" — override in compose env block
DATABASE_URL=postgresql+asyncpg://racademy:racademy@localhost:5433/racademy

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ── Storage (MinIO local / Cloudflare R2 prod) ───────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=racademy-dev

# ── Email (Mailpit local / Gmail SMTP prod) ──────────────────────
# Dev (Mailpit, anonymous):
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@coachito.dev
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_START_TLS=false
#
# Prod with Gmail SMTP (port 587, STARTTLS) — uncomment + fill:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char App Password (NOT account pwd)
# SMTP_FROM=you@gmail.com             # Gmail rewrites custom From → this addr
# SMTP_USE_TLS=false
# SMTP_START_TLS=true
#
# Gmail App Password setup:
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Create a new app password for "Coachito" → Google returns 16 chars
#   4. Paste into SMTP_PASSWORD above (with or without spaces)

# ── Google OAuth ─────────────────────────────────────────────────
# Hidden + disabled in PoC. Set ENABLE_GOOGLE_OAUTH=true to re-enable.
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI (Gemini draft summaries) ──────────────────────────────────
# Get a key at https://aistudio.google.com/apikey (free tier covers dev).
# Leave blank to disable AI drafting; the endpoint returns 503 in that state.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=12

# ── Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=

# ── Runtime ──────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Frontend (Vite) ──────────────────────────────────────────────
# Support WhatsApp number for manual upgrade flow (no leading +, country code prefix).
VITE_SUPPORT_WA_NUMBER=6281234567890
